// ==UserScript==
// @name         Sarathi Auto FaceAuth++ (Secure 3.3)
// @namespace    http://tampermonkey.net/
// @version      3.31
// @description  Auto + Manual FaceAuth with webcam, upload, preview, and secure device key activation
// @match        https://sarathi.parivahan.gov.in/sarathiservice/authenticationaction.do*
// @grant        none
// ==/UserScript==

(async function() {
'use strict';

/* ---------- MASTER DEVICE KEY ---------- */
const MASTER_DEVICE_KEY = "MY_SECRET_DEVICE_KEY_123"; // Never expose externally

/* ---------- HELPER: SHA-256 HASH ---------- */
async function getDeviceHash(masterKey) {
    const fp = [
        navigator.userAgent,
        navigator.platform,
        navigator.hardwareConcurrency,
        screen.width,
        screen.height,
        new Date().getTimezoneOffset()
    ].join("||");
    const combined = masterKey + "||" + fp;
    const encoder = new TextEncoder();
    const data = encoder.encode(combined);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    return Array.from(new Uint8Array(hashBuffer))
        .map(b => b.toString(16).padStart(2,"0"))
        .join("");
}

/* ---------- DEVICE ACTIVATION WITH PASTE SUPPORT ---------- */
async function ensureActivation() {
    const expectedHash = await getDeviceHash(MASTER_DEVICE_KEY);
    let storedKey = localStorage.getItem("sarathiDeviceKey");

    if (storedKey !== expectedHash) {
        const overlay = document.createElement("div");
        overlay.style.position = "fixed";
        overlay.style.top = 0;
        overlay.style.left = 0;
        overlay.style.width = "100%";
        overlay.style.height = "100%";
        overlay.style.background = "rgba(0,0,0,0.6)";
        overlay.style.zIndex = "9999999";
        overlay.style.display = "flex";
        overlay.style.alignItems = "center";
        overlay.style.justifyContent = "center";

        const box = document.createElement("div");
        box.style.background = "#fff";
        box.style.padding = "20px";
        box.style.borderRadius = "8px";
        box.style.textAlign = "center";
        box.style.minWidth = "320px";
        box.style.fontFamily = "Arial";

        const title = document.createElement("h3");
        title.innerText = "Activate Device (Secure)";
        box.appendChild(title);

        const input = document.createElement("input");
        input.type = "text";
        input.placeholder = "Enter Device Key";
        input.style.width = "80%";
        input.style.padding = "8px";
        input.style.marginTop = "10px";
        input.onpaste = (e) => { return true; };
        box.appendChild(input);

        const pasteBtn = document.createElement("button");
        pasteBtn.innerText = "📋 Paste Key";
        pasteBtn.style.marginTop = "10px";
        pasteBtn.style.marginLeft = "5px";
        pasteBtn.style.padding = "6px 12px";
        pasteBtn.style.cursor = "pointer";
        pasteBtn.onclick = async () => {
            try {
                const text = await navigator.clipboard.readText();
                input.value = text.trim();
            } catch {
                alert("Failed to read clipboard. Use Ctrl+V manually.");
            }
        };
        box.appendChild(pasteBtn);

        const btn = document.createElement("button");
        btn.innerText = "Activate";
        btn.style.marginTop = "15px";
        btn.style.padding = "8px 16px";
        btn.style.background = "#28a745";
        btn.style.color = "#fff";
        btn.style.border = "none";
        btn.style.borderRadius = "5px";
        btn.style.cursor = "pointer";
        box.appendChild(btn);

        const msg = document.createElement("div");
        msg.style.marginTop = "10px";
        msg.style.fontSize = "13px";
        msg.style.color = "red";
        box.appendChild(msg);

        overlay.appendChild(box);
        document.body.appendChild(overlay);

        return new Promise(resolve => {
            btn.onclick = async () => {
                const key = input.value.trim();
                if (!key) return;
                if (key === expectedHash) {
                    localStorage.setItem("sarathiDeviceKey", key);
                    overlay.remove();
                    resolve(true);
                } else {
                    msg.innerText = "❌ Invalid device key for this browser!";
                }
            };
        });
    }
    return true;
}

/* ---------- NOTIFICATIONS ---------- */
function showNotification(msg, color = "#28a745") {
    const box = document.createElement("div");
    box.innerText = msg;
    box.style.position = "fixed";
    box.style.top = "100px";
    box.style.right = "20px";
    box.style.padding = "12px 18px";
    box.style.background = color;
    box.style.color = "#fff";
    box.style.fontSize = "14px";
    box.style.borderRadius = "6px";
    box.style.zIndex = "999999";
    box.style.boxShadow = "0 4px 10px rgba(0,0,0,0.2)";
    box.style.fontFamily = "Arial";
    document.body.appendChild(box);
    setTimeout(() => box.remove(), 20000);
}

/* ---------- IMAGE PREVIEW ---------- */
function showApplImage() {
    if (!window.applimg) return;
    let box = document.getElementById("facePreviewBox");
    if (!box) {
        box = document.createElement("div");
        box.id = "facePreviewBox";
        box.style.position = "fixed";
        box.style.bottom = "110px";
        box.style.right = "20px";
        box.style.background = "#fff";
        box.style.zIndex = "999999";
        box.style.padding = "5px";
        box.style.textAlign = "center";

        const label = document.createElement("div");
        label.innerText = "Original";
        label.style.fontSize = "12px";
        label.style.fontWeight = "bold";
        label.style.marginBottom = "4px";

        const img = document.createElement("img");
        img.id = "facePreviewImg";
        img.style.width = "80px";
        img.style.height = "80px";

        box.appendChild(label);
        box.appendChild(img);
        document.body.appendChild(box);
    }
    document.getElementById("facePreviewImg").src = window.applimg;
}

/* ---------- CAMERA ---------- */
let video, canvas, ctx;
async function startCamera() {
    await ensureActivation();
    if (video) return;
    const camBox = document.createElement("div");
    camBox.style.position = "fixed";
    camBox.style.bottom = "105px";
    camBox.style.right = "120px";
    camBox.style.zIndex = "999999";
    camBox.style.background = "#fff";
    camBox.style.padding = "5px";
    camBox.style.textAlign = "center";

    const label = document.createElement("div");
    label.innerText = "OBS";
    label.style.fontSize = "12px";
    label.style.fontWeight = "bold";
    label.style.marginBottom = "4px";

    video = document.createElement("video");
    video.autoplay = true;
    video.style.width = "80px";
    video.style.height = "80px";

    camBox.appendChild(label);
    camBox.appendChild(video);
    document.body.appendChild(camBox);

    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;

    canvas = document.createElement("canvas");
    ctx = canvas.getContext("2d");
    showNotification("📷 Camera Started", "#007bff");
}

function captureFace() {
    ensureActivation().then(() => {
        if (!video) return;
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0);
        window.applimg = canvas.toDataURL("image/jpeg", 0.9);
        showApplImage();
        showNotification("📸 Image Captured", "#28a745");
    });
}

/* ---------- IMAGE UPLOAD ---------- */
const fileInput = document.createElement("input");
fileInput.type = "file";
fileInput.accept = "image/*";
fileInput.style.display = "none";
document.body.appendChild(fileInput);
fileInput.onchange = function() {
    ensureActivation().then(() => {
        const file = this.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            window.applimg = e.target.result;
            showApplImage();
            showNotification("🖼 Image Uploaded", "#28a745");
        };
        reader.readAsDataURL(file);
    });
};

/* ---------- SEND FACEAUTH ---------- */
async function sendFaceAuth() {
    await ensureActivation();
    const applno = document.getElementById("llappln")?.value;
    const rtocode = document.getElementById("rtocode")?.value;
    if (!applno || !rtocode) {
        showNotification("❌ Missing Application Data", "#dc3545");
        return;
    }
    if (!window.applimg || window.applimg.length < 1000) {
        showNotification("⚠ Capture or Upload image first", "#ffc107");
        return;
    }
    try {
        showNotification("⬆ Sending FaceAuth...", "#007bff");
        if (typeof faceAuthStatus === "function") {
            try { await faceAuthStatus(); } catch (e) {}
        }
        const data = new URLSearchParams({
            applno,
            rtocode,
            faceres: "1",
            CapPho: window.applimg
        });
        const res = await fetch("/sarathiservice/saveFaceAuthData.do", {
            method: "POST",
            credentials: "same-origin",
            headers: {
                "X-Requested-With": "XMLHttpRequest",
                "Content-Type": "application/x-www-form-urlencoded"
            },
            body: data
        });
        if (res.status === 200) {
            showNotification("✅ Face Authentication Successful", "#28a745");
        } else {
            showNotification("❌ Face Authentication Failed", "#dc3545");
        }
    } catch (err) {
        console.error(err);
        showNotification("⚠ FaceAuth Request Error", "#ffc107");
    }
}

/* ---------- BUTTON CREATION HELPER ---------- */
function createButton(text, bottom, right, color, onclick) {
    const btn = document.createElement("button");
    btn.innerText = text;
    btn.style.position = "fixed";
    btn.style.bottom = bottom + "px";
    btn.style.right = right + "px";
    btn.style.padding = "10px 16px";
    btn.style.background = color;
    btn.style.color = "#fff";
    btn.style.border = "none";
    btn.style.borderRadius = "6px";
    btn.style.fontSize = "14px";
    btn.style.cursor = "pointer";
    btn.style.zIndex = "999999";
    btn.onclick = onclick;
    document.body.appendChild(btn);
    return btn;
}

/* ---------- CREATE BUTTONS ---------- */
createButton("🚀 Send FaceAuth Data", 18, 140, "#00cc66", sendFaceAuth);
createButton("📷 Start Camera", 60, 20, "#007bff", startCamera);
createButton("📸 Capture Face", 60, 160, "#ff9800", captureFace);
createButton("📂 Upload Image", 60, 300, "#6f42c1", () => fileInput.click());

/* ---------- ENABLE CAPTURE BUTTON ---------- */
setInterval(() => {
    const btn = document.getElementById("capphto1");
    if (btn) {
        btn.disabled = false;
        btn.removeAttribute("disabled");
        btn.style.pointerEvents = "auto";
    }
}, 300);

/* ---------- AUTO WATCHER FOR IMAGE ---------- */
const watcher = setInterval(() => {
    if (window.applimg && window.applimg.length > 1000) {
        clearInterval(watcher);
        console.log("📸 applimg detected — waiting...");
        showApplImage();
        showNotification("📸 Image detected...", "#007bff");
    }
}, 300);

/* ---------- INITIAL ACTIVATION CHECK ON SCRIPT LOAD ---------- */
await ensureActivation();

})();
